# Public browser configuration. These values are embedded in the client bundle.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=sb_publishable_your_public_key

# Server-side canonical/Open Graph origin. Set this in production to avoid
# trusting forwarded Host headers for public share metadata.
PUBLIC_SITE_URL=https://your-domain.example
